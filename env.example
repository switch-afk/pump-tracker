# ── Discord ──────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here

# Channel IDs (right-click channel → Copy ID in Discord with Developer Mode on)
CH_NEW_TOKENS=1234567890123456789
CH_SIGNALS=1234567890123456789
CH_GRADUATED=1234567890123456789
CH_TRADE_ALERTS=1234567890123456789
CH_LOGS=1234567890123456789

# ── QuickNode HTTP (5 endpoints) ─────────────
QN_HTTP_1=https://your-endpoint-1.solana-mainnet.quiknode.pro/YOUR_TOKEN/
QN_HTTP_2=https://your-endpoint-2.solana-mainnet.quiknode.pro/YOUR_TOKEN/
QN_HTTP_3=https://your-endpoint-3.solana-mainnet.quiknode.pro/YOUR_TOKEN/
QN_HTTP_4=https://your-endpoint-4.solana-mainnet.quiknode.pro/YOUR_TOKEN/
QN_HTTP_5=https://your-endpoint-5.solana-mainnet.quiknode.pro/YOUR_TOKEN/

# ── QuickNode WebSocket (5 endpoints) ────────
QN_WS_1=wss://your-endpoint-1.solana-mainnet.quiknode.pro/YOUR_TOKEN/
QN_WS_2=wss://your-endpoint-2.solana-mainnet.quiknode.pro/YOUR_TOKEN/
QN_WS_3=wss://your-endpoint-3.solana-mainnet.quiknode.pro/YOUR_TOKEN/
QN_WS_4=wss://your-endpoint-4.solana-mainnet.quiknode.pro/YOUR_TOKEN/
QN_WS_5=wss://your-endpoint-5.solana-mainnet.quiknode.pro/YOUR_TOKEN/

# ── Optional ──────────────────────────────────
LOG_LEVEL=info    # debug | info | warn | error
